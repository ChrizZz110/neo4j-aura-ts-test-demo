{
  "name": "neo4j-aura-audi-demo",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "postinstall": "npm run build",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch --runInBand"
  },
  "dependencies": {
    "express": "^4.19.2",
    "neo4j-driver": "^5.23.0",
    "uuid": "^9.0.1",
    "typescript": "^5.6.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "^9.0.8",
    "jest": "29.7.0",
    "ts-jest": "29.1.1",
    "supertest": "^6.3.4",
    "ts-node-dev": "^2.0.0"
  }
}
